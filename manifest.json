{
    "manifest_version": 3,
    "name": "Link_in",
    "version": "1.0",
    "description": "Link_in - Site parking extension",
    "permissions": ["activeTab", "tabs", "storage"],
    "host_permissions": [
      "http://localhost:3000/*",
      "http://*:3000/*",
      "http://218.235.89.145:50001/*",
      "http://*:50001/*"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' data: blob: http://localhost:* https: http:; font-src 'self'"
    },
    "action": {
      "default_title": "Link_in",
      "default_icon": {
        "16": "icons/link.png",
        "32": "icons/link.png",
        "48": "icons/link.png",
        "128": "icons/link.png"
      }
    },
    "background": {
      "service_worker": "background.js"
    },
    "icons": {
      "16": "icons/link.png",
      "32": "icons/link.png",
      "48": "icons/link.png",
      "128": "icons/link.png"
    }
  } 